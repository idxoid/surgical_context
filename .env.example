# Neo4j local Docker defaults
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Local storage
LANCEDB_PATH=./data/lancedb
HISTORY_MODE=local
HISTORY_DB_PATH=./data/history/surgical_context.sqlite3
HISTORY_RETENTION_DAYS=
DEFAULT_WORKSPACE_ID=local/surgical_context@main

# Auth
AUTH_REQUIRED=false

# Local model routing
MODEL_PREFERENCE=auto
OLLAMA_MODEL=llama3

# Optional cloud model routing
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# GitHub (optional)
GITHUB_CLIENT_ID=

# HuggingFace
HF_HUB_DISABLE_IMPLICIT_TOKEN=1
