# Neo4j local Docker defaults
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
# Skip Aura probe and connect only to NEO4J_URI (recommended for local dev)
NEO4J_LOCAL_ONLY=1

# Optional Neo4j Aura (cloud-first when set and NEO4J_LOCAL_ONLY is unset)
# NEO4JAURA_USERNAME=
# NEO4JAURA_PASSWORD=
# NEO4J_INSTANCENAME=

# Local storage
LANCEDB_PATH=./data/lancedb
HISTORY_MODE=local
HISTORY_DB_PATH=./data/history/surgical_context.sqlite3
HISTORY_RETENTION_DAYS=
DEFAULT_WORKSPACE_ID=local/surgical_context@main

# In-memory editor overlay (unsaved buffers in context_engine RAM)
OVERLAY_MAX_ENTRIES=256
OVERLAY_TTL_SECONDS=86400

# Auth
AUTH_REQUIRED=false
# Unauthenticated identity/workspace headers are ignored unless explicitly trusted.
# Keep false outside controlled local/test use; the extension bootstraps a signed token.
TRUST_CLIENT_USER_HEADER=false
TRUST_CLIENT_WORKSPACE_HEADER=false

# Incremental indexing
INDEX_QUEUE_MAX_PENDING=500
INDEX_QUEUE_DEBOUNCE_MS=500
INDEX_QUEUE_BATCH_SIZE=50
GIT_DELTA_POLL_SECONDS=60

# Local model routing (local-first defaults)
MODEL_PREFERENCE=ollama
OLLAMA_MODEL=llama3
# Qwen3: disable internal reasoning (OLLAMA_THINK=false) and cap output length for latency.
# OLLAMA_NUM_PREDICT=768
# OLLAMA_NUM_CTX=8192
# OLLAMA_THINK=false

# Cloud LLM opt-in: must be true for MODEL_PREFERENCE=auto|claude to call Anthropic
ALLOW_CLOUD_LLM=false
ANTHROPIC_API_KEY=
# Default when unset: claude-sonnet-4-6 (replaces retired claude-sonnet-4-20250514)
ANTHROPIC_MODEL=

# GitHub (optional)
GITHUB_CLIENT_ID=

# HuggingFace / embeddings (see context_engine/database/lancedb_client.py — EMBED_MODEL)
HF_HUB_DISABLE_IMPLICIT_TOKEN=1
# After the model is cached under ~/.cache/huggingface, you can avoid Hub HTTP entirely:
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
# Embeddings device: cpu | cuda | mps (auto-falls back to cpu on sm_61 GPUs e.g. GTX 1050 Ti)
# EMBED_DEVICE=cpu
# Quiet NVIDIA driver/CUDA probe noise when you only want CPU (Sidecar loads ST at import):
# CUDA_VISIBLE_DEVICES=
# If a local HTTP(S)_PROXY breaks Hub downloads, either fix the proxy or bypass it for HF hosts, e.g.:
# NO_PROXY=127.0.0.1,localhost,::1,huggingface.co,hf.co,cdn-lfs.huggingface.co
